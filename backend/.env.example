# Local dev defaults to SQLite; no value needed to run locally.
# DATABASE_URL=sqlite:///./test.db

# Production (Azure Database for PostgreSQL). Use the flexible-server connection
# string; sslmode=require is enforced by Azure.
# DATABASE_URL=postgresql://USER:PASSWORD@SERVER.postgres.database.azure.com:5432/ungovernable?sslmode=require

API_TITLE=Ungovernable API
API_VERSION=1.0.0

# Comma-separated extra CORS origins (not needed when SPA is served same-origin).
# EXTRA_CORS_ORIGINS=https://your-app.azurewebsites.net
